@model PhoneStore.Models.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <div class="mb-4">
                    <div style="font-size: 80px;">✅</div>
                </div>
                
                <h2 class="text-success mb-3">Đặt hàng thành công!</h2>
                <p class="lead mb-4">Cảm ơn bạn đã đặt hàng tại CloudShop</p>
                
                <div class="alert alert-info">
                    <h5>Mã đơn hàng: <strong>#@Model.Id</strong></h5>
                    <p class="mb-0">Chúng tôi sẽ liên hệ với bạn trong thời gian sớm nhất để xác nhận đơn hàng</p>
                </div>
                
                <div class="card mb-4">
                    <div class="card-body text-start">
                        <h5 class="card-title mb-3">📦 Thông tin đơn hàng</h5>
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <strong>Người nhận:</strong> @Model.CustomerName
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>Số điện thoại:</strong> @Model.CustomerPhone
                            </div>
                            <div class="col-12 mb-2">
                                <strong>Địa chỉ:</strong> @Model.ShippingAddress
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Notes))
                            {
                                <div class="col-12 mb-2">
                                    <strong>Ghi chú:</strong> @Model.Notes
                                </div>
                            }
                            <div class="col-md-6 mb-2">
                                <strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")
                            </div>
                            <div class="col-md-6 mb-2">
                                <strong>Tổng tiền:</strong> <span class="text-danger">@Model.TotalAmount.ToString("N0") đ</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                        🏠 Về trang chủ
                    </a>
                    <a asp-controller="Phones" asp-action="Index" class="btn btn-outline-primary btn-lg">
                        📱 Tiếp tục mua sắm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
