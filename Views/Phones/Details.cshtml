@model PhoneStore.Models.Phone
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var discount = 15 + (Model.Id * 5);
    var oldPrice = Model.Price * (100 + discount) / 100;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Phones" asp-action="Index">Sản phẩm</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-5">
        <div class="product-image" style="height: 400px; border: 1px solid #e0e0e0; border-radius: 10px; position: relative; display: flex; align-items: center; justify-content: center;">
            <span class="badge-sale">-@discount%</span>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
            }
            else
            {
                <div style="font-size: 150px; color: #ddd;">📱</div>
            }
        </div>
    </div>
    
    <div class="col-md-7">
        <h1 class="mb-3">@Model.Name</h1>
        <p class="text-muted fs-5 mb-3">Thương hiệu: <strong>@Model.Brand</strong></p>
        
        <div class="product-price mb-4">
            <span class="price-current" style="font-size: 32px;">@Model.Price.ToString("N0") VNĐ</span>
            <span class="price-old" style="font-size: 18px;">@oldPrice.ToString("N0") VNĐ</span>
        </div>
        
        @if (Model.Stock > 0)
        {
            <div class="alert alert-success">
                ✅ Còn hàng: <strong>@Model.Stock sản phẩm</strong>
            </div>
            
            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mb-4">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-primary btn-lg" style="padding: 15px 50px;">
                    🛒 THÊM VÀO GIỎ HÀNG
                </button>
            </form>
        }
        else
        {
            <div class="alert alert-danger">
                ❌ Sản phẩm tạm hết hàng
            </div>
        }
        
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">📝 Mô tả sản phẩm</h5>
                <p class="card-text">@Model.Description</p>
            </div>
        </div>
        
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">⚙️ Thông số kỹ thuật</h5>
                <p class="card-text">@Model.Specifications</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary">
        ← Quay lại danh sách sản phẩm
    </a>
</div>

<!-- Features -->
<div class="row mt-5">
    <div class="col-md-3 text-center">
        <div class="p-3 border rounded">
            <div style="font-size: 40px;">🚚</div>
            <h6>Miễn phí vận chuyển</h6>
        </div>
    </div>
    <div class="col-md-3 text-center">
        <div class="p-3 border rounded">
            <div style="font-size: 40px;">✅</div>
            <h6>Bảo hành 12 tháng</h6>
        </div>
    </div>
    <div class="col-md-3 text-center">
        <div class="p-3 border rounded">
            <div style="font-size: 40px;">💳</div>
            <h6>Trả góp 0%</h6>
        </div>
    </div>
    <div class="col-md-3 text-center">
        <div class="p-3 border rounded">
            <div style="font-size: 40px;">🎁</div>
            <h6>Quà tặng hấp dẫn</h6>
        </div>
    </div>
</div>
