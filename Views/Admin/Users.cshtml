@model IEnumerable<PhoneStore.Models.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="row mb-4">
    <div class="col">
        <h2>👥 Quản lý người dùng</h2>
    </div>
    <div class="col text-end">
        <a asp-action="Index" class="btn btn-secondary">← Quay lại</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Tên đăng nhập</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th>Địa chỉ</th>
                        <th>Ngày tạo</th>
                        <th>Loại</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td><strong>@user.Username</strong></td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>@user.Phone</td>
                            <td>@user.Address</td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (user.IsAdmin)
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-info">Khách hàng</span>
                                }
                            </td>
                            <td>
                                @if (!user.IsAdmin)
                                {
                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline" 
                                          onsubmit="return confirm('Bạn có chắc muốn xóa người dùng này?');">
                                        <button type="submit" class="btn btn-sm btn-danger">🗑️ Xóa</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="mt-3">
            <p class="text-muted">
                <strong>Tổng số người dùng:</strong> @Model.Count() 
                (Admin: @Model.Count(u => u.IsAdmin), Khách hàng: @Model.Count(u => !u.IsAdmin))
            </p>
        </div>
    </div>
</div>
