@model PhoneStore.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="row mb-4">
    <div class="col">
        <h2>📦 Chi tiết đơn hàng #@Model.Id</h2>
    </div>
    <div class="col text-end">
        <a asp-action="Orders" class="btn btn-secondary">← Quay lại</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-md-8">
        <!-- Thông tin khách hàng -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">👤 Thông tin khách hàng</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Họ tên:</strong> @Model.CustomerName</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Số điện thoại:</strong> @Model.CustomerPhone</p>
                    </div>
                    <div class="col-12">
                        <p><strong>Địa chỉ:</strong> @Model.ShippingAddress</p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <p><strong>Ghi chú:</strong> @Model.Notes</p>
                }
            </div>
        </div>

        <!-- Chi tiết sản phẩm -->
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">📱 Sản phẩm đã đặt</h5>
            </div>
            <div class="card-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderDetails)
                        {
                            <tr>
                                <td>@item.PhoneName</td>
                                <td>@item.Price.ToString("N0") đ</td>
                                <td>@item.Quantity</td>
                                <td class="fw-bold">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end"><strong>Tổng cộng:</strong></td>
                            <td class="fw-bold text-primary fs-5">@Model.TotalAmount.ToString("N0") đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <!-- Trạng thái đơn hàng -->
        <div class="card">
            <div class="card-header bg-warning">
                <h5 class="mb-0">📊 Trạng thái đơn hàng</h5>
            </div>
            <div class="card-body">
                <p><strong>Ngày đặt:</strong><br>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Trạng thái hiện tại:</strong><br>
                    @switch (Model.Status)
                    {
                        case "Pending":
                            <span class="badge bg-warning fs-6">Chờ xử lý</span>
                            break;
                        case "Processing":
                            <span class="badge bg-info fs-6">Đang xử lý</span>
                            break;
                        case "Shipped":
                            <span class="badge bg-primary fs-6">Đang giao</span>
                            break;
                        case "Delivered":
                            <span class="badge bg-success fs-6">Đã giao</span>
                            break;
                        case "Cancelled":
                            <span class="badge bg-danger fs-6">Đã hủy</span>
                            break;
                    }
                </p>

                <hr>

                <h6>Cập nhật trạng thái:</h6>
                <form asp-action="UpdateOrderStatus" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <select name="status" class="form-select mb-2">
                        <option value="Pending" selected="@(Model.Status == "Pending")">Chờ xử lý</option>
                        <option value="Processing" selected="@(Model.Status == "Processing")">Đang xử lý</option>
                        <option value="Shipped" selected="@(Model.Status == "Shipped")">Đang giao</option>
                        <option value="Delivered" selected="@(Model.Status == "Delivered")">Đã giao</option>
                        <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Đã hủy</option>
                    </select>
                    <button type="submit" class="btn btn-primary w-100">Cập nhật</button>
                </form>
            </div>
        </div>
    </div>
</div>
