<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CloudShop</title>
    <link rel="icon" type="image/png" href="~/raw/icon.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PhoneStore.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sakura.css" asp-append-version="true" />
</head>
<body>
    <!-- Tree Decorations -->
    <div class="tree-decoration-top"></div>
    <div class="tree-decoration-bottom"></div>
    
    <!-- Top Header -->
    <div class="top-header">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div class="hotline">
                    📞 1900 636 648
                </div>
                <div>
                    <small>Miễn phí vận chuyển toàn quốc</small>
                </div>
            </div>
        </div>
    </div>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                ☁️ CloudShop
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">TRANG CHỦ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Phones" asp-action="Index">SẢN PHẨM</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">GIỚI THIỆU</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">BLOG</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">LIÊN HỆ</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Cart" asp-action="Index">
                            <span style="font-size: 20px;">🛒</span> Giỏ hàng
                        </a>
                    </li>
                    @if (Context.Session.GetString("UserName") != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                👤 @Context.Session.GetString("UserName")
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout">Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                🔐 Đăng nhập
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="main-footer">
        <div class="container">
            <div class="row">
                <!-- Company Info -->
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="footer-title">CLOUDSHOP</h5>
                    <p class="footer-company">CÔNG TY TNHH CLOUDSHOP</p>
                    <p class="footer-text">
                        <strong>Giấy phép kinh doanh:</strong> 0313728397<br>
                        Sở Kế hoạch và Đầu tư thành phố Hồ Chí Minh
                    </p>
                    <p class="footer-text">
                        Tất cả mẫu website sử dụng đều được thiết kế và lập trình riêng
                    </p>
                </div>

                <!-- Contact Info -->
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="footer-title">THÔNG TIN LIÊN HỆ</h5>
                    <div class="footer-contact">
                        <p>
                            <i>📍</i>
                            <span>107/323 Cách Mạng Tháng Tám,<br>phường Tân Sơn Nhất, TPHCM</span>
                        </p>
                        <p>
                            <i>📞</i>
                            <span><strong>1900 636 648</strong></span>
                        </p>
                        <p>
                            <i>💼</i>
                            <span>Bấm 108 - Phòng kinh doanh<br>Bấm 103 - Phòng kỹ thuật</span>
                        </p>
                        <p>
                            <i>✉️</i>
                            <span>info@phonestore.vn</span>
                        </p>
                    </div>
                </div>

                <!-- Map -->
                <div class="col-lg-4 col-md-12 mb-4">
                    <h5 class="footer-title">BẢN ĐỒ</h5>
                    <div class="footer-map">
                        <iframe 
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.0!2d106.6!3d10.8!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTDCsDQ4JzAwLjAiTiAxMDbCsDM2JzAwLjAiRQ!5e0!3m2!1svi!2s!4v1234567890"
                            width="100%" 
                            height="200" 
                            style="border:0; border-radius: 8px;" 
                            allowfullscreen="" 
                            loading="lazy">
                        </iframe>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Copyright -->
        <div class="footer-bottom">
            <div class="container">
                <p class="text-center mb-0">
                    Cửa hàng điện thoại CloudShop ❄️
                </p>
            </div>
        </div>
    </footer>
    <!-- Toast Notification -->
    @if (TempData["Message"] != null || TempData["Success"] != null)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
            <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header bg-success text-white">
                    <strong class="me-auto">✅ Thành công</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    @(TempData["Message"] ?? TempData["Success"])
                </div>
            </div>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
            <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header bg-danger text-white">
                    <strong class="me-auto">❌ Lỗi</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    @TempData["Error"]
                </div>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/sakura.js" asp-append-version="true"></script>
    <script>
        // Auto hide toast after 3 seconds
        document.addEventListener('DOMContentLoaded', function() {
            var toasts = document.querySelectorAll('.toast');
            toasts.forEach(function(toast) {
                setTimeout(function() {
                    var bsToast = new bootstrap.Toast(toast);
                    bsToast.hide();
                }, 3000);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
